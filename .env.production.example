# ─────────────────────────────────────────────────────
# JnConta — Variables de entorno PRODUCCIÓN
# Copia como .env.production y rellena los valores reales
# NUNCA subas .env.production a git
# ─────────────────────────────────────────────────────

# ── Base de datos ──────────────────────────────────────
DB_USER=jnconta_user
DB_PASSWORD=CAMBIAR_contraseña_segura_minimo_32_chars
DB_NAME=jnconta_prod

# ── API / JWT ──────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_string_aleatorio_minimo_64_caracteres
APP_URL=https://jnconta.com
NODE_ENV=production

# ── Stripe ─────────────────────────────────────────────
# Llaves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXX
# Webhook en: https://dashboard.stripe.com/webhooks
# Endpoint a registrar: https://jnconta.com/api/subscriptions/webhook
# Eventos: checkout.session.completed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Email — SendGrid ───────────────────────────────────
# Crear en: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@jnconta.com
SENDGRID_FROM_NAME=JnConta

# ── IA — Gemini ────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── Banxico (tipo de cambio) ───────────────────────────
BANXICO_TOKEN=

# ─────────────────────────────────────────────────────
# INSTRUCCIONES DE DESPLIEGUE
# ─────────────────────────────────────────────────────
# 1. En el servidor (Ubuntu 22.04+):
#    apt install docker.io docker-compose-plugin certbot
#
# 2. Obtener certificado SSL:
#    certbot certonly --standalone -d jnconta.com -d www.jnconta.com
#
# 3. Copiar archivos al servidor y crear .env.production
#
# 4. Inicializar la base de datos con planes:
#    docker compose -f docker-compose.prod.yml --env-file .env.production \
#      run --rm jnconta-api node prisma/seed-prod.js
#
# 5. Levantar todos los servicios:
#    docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# 6. Renovación automática de SSL (agregar a crontab):
#    0 3 * * * certbot renew --quiet && docker compose restart jnconta-nginx
